# Copiar a .env y ajustar. Nunca commitear secretos reales.

DATABASE_URL="file:./dev.db"

# Firma access JWT (o usar JWT_SECRET como alias legacy)
JWT_ACCESS_SECRET="cambiar-en-produccion-min-32-chars"
JWT_ACCESS_EXPIRES_SEC=900

# Firma refresh JWT (obligatorio)
JWT_REFRESH_SECRET="otro-secreto-largo-distinto-del-access"
JWT_REFRESH_EXPIRES_SEC=604800

# Si solo existe JWT_SECRET, se usa como access (ver auth.module)
# JWT_SECRET="..."

# Una URL o varias separadas por coma (Docker front en :8080, Vite en :5173)
FRONTEND_ORIGIN="http://localhost:5173,http://localhost:8080"
# Puerto por defecto 4000 (3000 suele estar ocupado por otros servicios)
PORT=4000

# Detrás de reverse proxy (nginx, cloud LB): IP cliente en X-Forwarded-For
# TRUST_PROXY=1

# URL pública del frontend (enlaces en correos de notificación)
# FRONTEND_PUBLIC_URL=http://localhost:8080

# Correo saliente (opcional). Sin SMTP_HOST solo hay notificaciones en la app.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@jikkosoft.local

# Mínimo de JP acreditados por formulario para avisar al colaborador (in-app + correo)
# JP_BALANCE_NOTIFY_MIN=100

# Solo entornos de prueba: un admin puede aprobar su propia solicitud de descanso
# REDEMPTION_ALLOW_SELF_APPROVE=1

# Validez del enlace «olvidé mi contraseña» (minutos)
# PASSWORD_RESET_EXPIRES_MIN=60

# Desactivar Swagger en producción si se prefiere
# SWAGGER_DISABLED=1
